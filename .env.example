# Compute Hedge Operator - environment configuration
#
# Copy to .env for local runs (`make run-operator` / `make run-console`), or feed the
# same keys into a Kubernetes Secret for in-cluster use (see config/secret.example.yaml).
#
# The golden rule: BLANK = mock, FILLED = live. Each source is auto-detected.
#   *_MODE = auto  -> live when its credentials/URL are present, otherwise mock
#   *_MODE = mock  -> always the bundled simulator
#   *_MODE = live  -> always the real integration (fails loudly if misconfigured)

# ----- General -----
CLUSTER_NAME=kind-compute-hedge
POLL_INTERVAL=2s

# ----- Shared auth (reused by every live HTTP client) -----
# Whatever token scheme Ornn hands over adapts here without a code change.
AUTH_SCHEME=Bearer
AUTH_HEADER=Authorization

# ----- Price feed (OCPI) -----
OCPI_MODE=auto
# Mock endpoint used when no live token is present:
OCPI_URL=http://mockocpi:8080
# Fill these to go live:
ORNN_API_TOKEN=
ORNN_API_BASE_URL=https://api.ornnai.com
ORNN_API_PRICE_PATH=/v1/prices

# ----- GPU telemetry -----
TELEMETRY_MODE=auto
# Mock exporter used when no Prometheus URL is present:
GPU_EXPORTER_URL=http://gpuexporter:8081
# Fill this to read real DCGM metrics via Prometheus:
PROMETHEUS_URL=
# {position} and {namespace} are substituted into the query:
TELEMETRY_QUERY=avg(DCGM_FI_DEV_GPU_UTIL{position="{position}"})

# ----- Marketplace write-back -----
MARKET_MODE=auto
MARKET_API_URL=
MARKET_API_PATH=/v1/marketplace/supply
# Safety switch: nothing is ever posted unless this is explicitly true.
MARKET_WRITE_ENABLED=false
